;====================================================
; load_boot_loader:
;     Carrega o Boot Loader (BL.BIN) na memï¿½ria.
;     Essa rotina ï¿½ chamada em start.inc para carregar o BL.BIN na memï¿½ria.
;     Essa rotina chama os recursos de \fs da classe fs16XXXX. 
;
load_boot_loader:
    nop
.initHardware:
	call init_ide0_master
.readFile:
	push eax
	push ebx 
    mov eax, dword boot_loader_name
    ;call fat16_read_file
	call fat16ReadFile
	jc .fail
	pop ebx
	pop eax
    clc
	ret
.fail:	
    ;@todo: Some message.
    ;push eax
	;push ebx
	;push ecx 
	;push edx
	mov esi, msm_load_boot_loader_fail 
	call lib32PrintString
	;pop edx 
	;pop ecx 
	;pop ebx 
	;pop eax 
	call _asm_refresh_screen 
	jmp $

msm_load_boot_loader_fail: db "load_boot_loader: fail.",13,10,0	
	
;----------------------------------------------
; start_bootloader:
;     Executa o Boot Loader do System4Nora. No modo texto apenas.
;
start_bootloader:

    call os_screen_clear
	call reset_cursor
	
    ;cabeï¿½alho PE.
    cmp byte [IMAGE_ADDRESS], byte 'L'
	je .ok
	
	;Erro.
    mov esi, bl_bl_nao_presente
	call os_output	

	;Debug
	jmp $
.ok:	
    ;Debug
	;Mostra o arquivo. (ou um pedaï¿½o dele.)
    ;mov esi, IMAGE_ADDRESS
	;call os_output
	
	mov esi, bl_bl_test
	call os_output
   
	;
	;@todo: Passar argumentos.
    ;
    ; al = modo de video
	; ebx = lfb.
    ;
	
	mov al, byte 'T' 
 	;mov al, byte 'G'                       ;Flag. (useing graphics)	
	;mov ebx, dword [ModeInfo_PhysBasePtr]  ;LFB address
	;mov ecx, dword [ModeInfo_XResolution]  ;Width in pixels.
	;mov edx, dword [ModeInfo_YResolution]  ;height in pixel.	
	
	;
	; Go!.
	;
	jmp 8:IMAGE_ADDRESS_ENTRY_POINT
	jmp $
	
	;jmp System4Nora_BootLoader  ;Passa o comando para o Boot Loader.  
	;call System4Nora_BootLoader 

.done:	
	mov eax, 0	
	RET
	
	;mov esi, bl_bl_fail_text
	;call os_output	
	
	;Opï¿½ï¿½o.
	JMP $
	

;;==================================================================
;; start_bootloader_on_graphic_mode:
;;     Executa o programa BL.BIN no modo grï¿½fico.
;;
;;
;;   **** PASSANDO O COMANDO PARA O BL.BIN    ****
;;
;;
;; @todo: Verificar antes se ele estï¿½ presenta na memï¿½ria.
;;
start_bootloader_on_graphic_mode:
;bootloaderStartOnGraphicMode:	
	;
	; Meta-Object: @todo:
	; ============
	;     O Boot Manager passar para o Boot Loader um Meta-Objeto na forma 
	; de vetor, contendo variï¿½veis e mï¿½todos.
	;     O principal mï¿½todo ï¿½ se passar ï¿½ _bmServices contendo o mï¿½todo
	; que o Boot Manager usa para oferecer serviï¿½os. Desse mï¿½do o Boot Manager
	; pode atuar como um mï¿½dulo do kernel em kernel mode. Para isso o
	; Boot Loader terï¿½ que passar esse mï¿½todo para o Kernel Base.
	;
	
	;
	; Prepara argumentos.
	;
	; EBP = BootBlock.
	; al = 'G'
	; ebx = LFB.
	;
	;
	
	;Prepara a tabela.
	mov ebp, dword BootBlock
	
	xor eax, eax
	mov eax, dword [ModeInfo_PhysBasePtr]  ;LFB address.	
	mov dword [BootBlock.lfb], eax	
	
	xor eax, eax
	mov ax, word [ModeInfo_XResolution]    ;Width in pixels.
	mov dword [BootBlock.x], eax 	
	
	xor eax, eax
	mov ax, word [ModeInfo_YResolution]    ;Height in pixel.
	mov dword [BootBlock.y], eax 	
	
	xor eax, eax
	mov al, byte [ModeInfo_BitsPerPixel]   ;bpp.
	mov dword [BootBlock.bpp], eax 


	xor eax, eax
	mov eax, dword META$FILE                 ;metafile address	
	mov dword [BootBlock.metafile_address], eax	
    
	;Continua...
	
	xor eax, eax
	mov al, byte 'G'                       ;Flag. (useing graphics)	
	mov ebx, dword [ModeInfo_PhysBasePtr]  ;LFB address (endereï¿½o fï¿½sico)
	mov ecx, ebp
	mov edx, ebp                           ;tabela
	
	;
    ; Go! ( Passa o comando para o entrypoint do Boot Loader. ) BL.BIN. 
    ;	
	
	;call _background_teste
	;call _background
	;call _fade_screen
	;jmp $
	
	
    ;cabeï¿½alho PE. no BL.BIN.
    cmp byte [IMAGE_ADDRESS], byte 'L'
	jne .peFail	

	mov esi, msg_bootloader_jumping
	call lib32PrintString
	call _asm_refresh_screen		
	
	;debug
	jmp $

	jmp 8:IMAGE_ADDRESS_ENTRY_POINT
	JMP $

; The file is not in memory
.peFail:
	mov esi, msg_bootloader_sig
	call lib32PrintString
	call _asm_refresh_screen		
    jmp $

msg_bootloader_sig     db "start_bootloader_on_graphic_mode: PE sig for BL",0	
msg_bootloader_jumping db "start_bootloader_on_graphic_mode: Passing command to BL",0	
	
;
; Messages
;

; Errors
bl_bl_fail_text      db "start_bootloader: Text mode fail", 13,10,0
bl_bl_fail_graphics  db "start_bootloader: Graphics mode fail", 13,10,0	
bl_bl_presente       db "start_bootloader: BL Validation", 13,10,0
bl_bl_nao_presente   db "start_bootloader: BL Validation", 13,10,0
bl_bl_test           db "start_bootloader: Passing command to BL", 13,10,0

